# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
*.whl

# ============================================================
# 虚拟环境
# ============================================================
.venv/
venv/
env/

# ============================================================
# 模型文件（几个 GB ~ 几百 GB，新机器 ModelScope 重下）
# ============================================================
**/models/*/
!**/models/.gitkeep

# ============================================================
# 编译产物
# ============================================================
build/
*.o
*.obj
*.a

# ============================================================
# xmake 缓存
# ============================================================
.xmake/

# ============================================================
# 手动复制的 Python C++ 扩展 .so（新机器需重新编译）
# ============================================================
InfiniCore/python/infinicore/lib/_infinicore*.so
# 保留 lib 目录结构
!InfiniCore/python/infinicore/lib/__init__.py

# ============================================================
# 大型第三方库（新机器需重新 clone）
# ============================================================
InfiniCore/third_party/cutlass/
InfiniCore/third_party/flash-attention/
InfiniCore/third_party/mate/

# ============================================================
# 备份的 .git 目录
# ============================================================
.git.bak/
**/.git.bak/

# ============================================================
# IDE
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================
# 系统 / 临时文件
# ============================================================
.DS_Store
Thumbs.db
/tmp/
InfiniLM/tmp/
*.log

# ============================================================
# InfiniCore 安装产物（新机器重建）
# ============================================================
/root/.infini/
